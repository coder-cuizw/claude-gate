# claude-gate 环境变量示例（复制为 .env 并按需修改）
# 所有 CG_ 前缀变量会覆盖配置文件中的同名项（见 internal/config）

# —— HTTP 服务 ——
CG_SERVER_ADDR=:8791

# —— PostgreSQL（配置数据）——
CG_POSTGRES_DSN=postgres://claude:claude@localhost:5432/claude_gate?sslmode=disable

# —— ClickHouse（请求明细）——
CG_CLICKHOUSE_DSN=clickhouse://claude:claude@localhost:9000/claude_gate

# —— Redis（热路径缓存 / 限流）——
CG_REDIS_ADDR=localhost:6379

# —— S3 / MinIO（请求体落盘）——
CG_S3_ENDPOINT=localhost:9100
CG_S3_BUCKET=claude-gate

# —— 鉴权 ——
CG_JWT_SECRET=please-change-me-in-prod
# 对称加密口令：可逆存储客户 API Key 明文与上游凭证，支持后台"重复查看"客户 Key。生产必须修改。
CG_ENCRYPTION_KEY=please-change-me-32+chars-secret

# —— 日志 ——
CG_LOG_LEVEL=info

# —— 并发上限（性能调优，见 docs/configuration.md）——
CG_GLOBAL_MAX_IN_FLIGHT=6000
