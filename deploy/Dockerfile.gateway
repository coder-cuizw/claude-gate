# claude-gate 网关多阶段构建
# 阶段一：编译
FROM golang:1.22-alpine AS builder
WORKDIR /src
# 先拷依赖清单，利用层缓存
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# 静态编译，去除调试信息
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/gateway ./cmd/gateway \
 && CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/migrate ./cmd/migrate

# 阶段二：运行（极简镜像）
FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata && adduser -D -u 10001 claude
COPY --from=builder /out/gateway /usr/local/bin/gateway
COPY --from=builder /out/migrate /usr/local/bin/migrate
COPY migrations /app/migrations
USER claude
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/gateway"]
